# Backend
APP_NAME=Modular Monolith Banking API
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/banking
JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_REQUESTS=50
RATE_LIMIT_WINDOW_SECONDS=60
LOG_LEVEL=INFO
WEBSOCKET_POLL_SECONDS=2
TWELVEDATA_API_KEY=decf7b9d1b22417c996e813d9a4a0e78
METALS_API_KEY=replace-with-api-key
MARKET_PRICE_CACHE_SECONDS=60
MARKET_TABLE_CACHE_SECONDS=5

# Database container
POSTGRES_DB=banking
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
